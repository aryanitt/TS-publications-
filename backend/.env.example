# Backend — copy to .env

PORT=5000

# Comma-separated frontend origins (CORS)
FRONTEND_URL=http://localhost:8080,http://localhost:5173

# Native PostgreSQL (install locally — no Docker)
# Windows: winget install PostgreSQL.PostgreSQL
# Then create DB: psql -U postgres -c "CREATE DATABASE \"CRM_dashboard\";"
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=CRM_dashboard

# Optional Redis cache
REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
ASSIGNMENT_QUEUE_INTERVAL_MS=30000
FOLLOWUP_REMINDER_INTERVAL_MS=300000
MAX_UPLOAD_BYTES=10485760
