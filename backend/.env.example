# Backend — local .env OR Hostinger Environment Variables panel

PORT=5000
HOST=0.0.0.0

# REQUIRED in production (NODE_ENV=production): app refuses to start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
NODE_ENV=production
JWT_SECRET=
JWT_EXPIRES=7d

# Admin seeding (used only when no admin user exists yet).
# If ADMIN_PASSWORD is empty, a random one-time password is printed to the log.
ADMIN_LOGIN_ID=ADMIN
ADMIN_EMAIL=admin@tspublication.in
ADMIN_PASSWORD=

# Comma-separated frontend origins (CORS)
FRONTEND_URL=https://ts-frontend-two.vercel.app,http://localhost:8080,http://localhost:5173

# MySQL — Hostinger hPanel → Databases → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name
DB_SSL=false
DB_CONNECT_TIMEOUT_MS=8000

# Hostinger example (from hPanel):
# DB_HOST=localhost
# DB_USER=u123456789_crm
# DB_PASSWORD=your_db_password
# DB_NAME=u123456789_crm_dashboard

# Optional Redis cache
REDIS_URL=

LOG_LEVEL=info
ASSIGNMENT_QUEUE_INTERVAL_MS=30000
FOLLOWUP_REMINDER_INTERVAL_MS=300000
MAX_UPLOAD_BYTES=10485760

# Callyzer call tracking (Connectors → API & Webhook in Callyzer portal)
CALLYZER_API_KEY=
CALLYZER_API_BASE_URL=https://api1.callyzer.co/api/v2.1
CALLYZER_HISTORY_DAYS=30
# Optional: secret you set in Callyzer webhook config (validates incoming webhooks)
CALLYZER_WEBHOOK_SECRET=
CALLYZER_TENANT_ID=default

# Google OAuth — one app for all employees (each employee connects their own account)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mediumturquoise-capybara-737767.hostingersite.com/api/auth/google/callback
GOOGLE_OAUTH_SUCCESS_URL=https://ts-frontend-two.vercel.app/employee/profile?google=connected
GOOGLE_OAUTH_ERROR_URL=https://ts-frontend-two.vercel.app/employee/profile?google=error

# OpenAI — add when ready for live AI insights
OPENAI_API_KEY=
# Model used for call transcript analysis (MoM, sentiment, pipeline stage)
OPENAI_CALL_MODEL=gpt-4o-mini
